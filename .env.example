BRAWL_API_TOKEN=your_brawlstars_api_token_here
BRAWL_API_BASE_URL=https://api.brawlstars.com/v1
PORT=3000
HOST=127.0.0.1
APP_BASE_URL=http://localhost:3000

# Optional: protect API routes with login
REQUIRE_LOGIN_FOR_API=true
SESSION_COOKIE_NAME=brawlgg_session
SESSION_SECRET=replace_with_random_long_secret
SESSION_TTL_SEC=604800
OAUTH_STATE_TTL_MS=600000

# Supercell OAuth/OIDC settings
SUPERCELL_OAUTH_CLIENT_ID=
SUPERCELL_OAUTH_CLIENT_SECRET=
SUPERCELL_OAUTH_AUTHORIZATION_URL=
SUPERCELL_OAUTH_TOKEN_URL=
SUPERCELL_OAUTH_USERINFO_URL=
SUPERCELL_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/supercell/callback
SUPERCELL_OAUTH_SCOPE=openid profile email
SUPERCELL_OAUTH_AUDIENCE=
